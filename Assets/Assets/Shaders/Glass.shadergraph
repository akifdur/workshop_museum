        },
        {
            "m_Id": "533b4a780bbb48e68639addcd70963f6"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "WorldToScreen",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float3 v = TransformWorldToHClipDir(ViewDirection, false);\n\n#if UNITY_UV_STARTS_AT_TOP\nv.y = -v.y;\n#endif\n\nv = v * 0.5 + 0.5;\n\nScreenCoords = v.xy;"
}

